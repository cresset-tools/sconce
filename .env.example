# Copy to `.env` (which is git-ignored). The sconce CLI loads it automatically
# from the working directory, so you don't need to pass --database-url or export
# anything. Command-line flags and real environment variables still override it.

# Postgres connection string used by all DB-backed commands (serve, ui, mirror,
# token, policy, license-create, grant, user-*, …).
DATABASE_URL=postgres://postgres:sconce@localhost:5432/sconce

# Optional: single-tenant admin-UI password (`sconce ui --single-tenant`).
# SCONCE_ADMIN_PASSWORD=change-me
